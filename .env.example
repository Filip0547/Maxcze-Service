# Email configuration
# Copy this file to .env and fill in your actual credentials
# MAIL_PROVIDER can be outlook, smtp or sendgrid.
# If omitted, the app uses sendgrid when SENDGRID_API_KEY is present; otherwise smtp.
MAIL_PROVIDER=outlook

# SMTP (Outlook/Microsoft, etc.)
MAIL_SERVER=smtp-mail.outlook.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_TIMEOUT=10
MAIL_USERNAME=your-email@outlook.com
MAIL_PASSWORD=your-password
MAIL_DEFAULT_SENDER=your-email@outlook.com
MAIL_RECIPIENT=your-email@outlook.com

# SendGrid (recommended fallback if Microsoft SMTP blocks authentication)
# SENDGRID_API_KEY=SG.xxxxx
# SENDGRID_FROM_EMAIL=your-verified-sender@yourdomain.com